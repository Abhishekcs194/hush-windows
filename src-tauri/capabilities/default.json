{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for all Hush windows",
  "windows": ["main", "bubble", "settings", "history"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "shell:allow-open"
  ]
}
